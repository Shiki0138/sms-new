# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# LINE API Configuration
VITE_LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
VITE_LINE_CHANNEL_SECRET=your_line_channel_secret
VITE_LINE_WEBHOOK_URL=https://your-domain.com/api/webhooks/line

# Instagram API Configuration
VITE_INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
VITE_INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
VITE_INSTAGRAM_WEBHOOK_URL=https://your-domain.com/api/webhooks/instagram

# Email Configuration (SMTP)
VITE_EMAIL_SMTP_HOST=smtp.gmail.com
VITE_EMAIL_SMTP_PORT=587
VITE_EMAIL_SMTP_USER=your_email@gmail.com
VITE_EMAIL_SMTP_PASS=your_app_specific_password
VITE_EMAIL_FROM_ADDRESS=noreply@your-salon.com
VITE_EMAIL_FROM_NAME=Your Salon Name

# Alternative: SendGrid Configuration
VITE_SENDGRID_API_KEY=your_sendgrid_api_key
VITE_SENDGRID_FROM_EMAIL=noreply@your-salon.com

# Webhook Security
VITE_WEBHOOK_SECRET=your_webhook_secret_key

# Application Settings
VITE_APP_NAME=美容サロン管理システム
VITE_APP_ENV=production
VITE_APP_URL=https://your-domain.com

# Plan Limits (Light Plan)
VITE_PLAN_MAX_CUSTOMERS=100
VITE_PLAN_MAX_RESERVATIONS_MONTHLY=50
VITE_PLAN_MAX_STAFF=3
VITE_PLAN_MAX_EMAILS_DAILY=50

# Feature Flags
VITE_ENABLE_LINE_API=true
VITE_ENABLE_INSTAGRAM_API=true
VITE_ENABLE_EMAIL_API=true
VITE_ENABLE_BULK_MESSAGING=true
VITE_ENABLE_ADVANCED_REPORTS=true

# Security Settings
VITE_JWT_SECRET=your_jwt_secret_key
VITE_ENCRYPTION_KEY=your_encryption_key

# Google Analytics (Optional)
VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X

# Sentry Error Tracking (Optional)
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id