# 🔐 SMS美容サロン管理システム 環境変数設定（セキュリティ強化版）

# === Supabase Configuration ===
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# サインアップ用（開発環境のみ）
# ⚠️ 本番環境では絶対に公開しないでください
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_for_dev_only

# === Application Configuration ===
VITE_APP_NAME=美容サロン管理システム
VITE_APP_VERSION=1.0.0

# === CORS Settings (Production Security) ===
# 本番環境では必ず実際のドメインを設定してください
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# === LINE Messaging API ===
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_WEBHOOK_URL=https://your-domain.com/api/webhooks/line

# === Instagram API ===
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_APP_ID=your_instagram_app_id
INSTAGRAM_APP_SECRET=your_instagram_app_secret

# === Email Configuration ===
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@yourdomain.com

# === AI Services ===
VITE_GEMINI_API_KEY=your_gemini_api_key

# === Dashboard Configuration ===
# デフォルトダッシュボードバリアント（8種類から選択可能）
VITE_DEFAULT_DASHBOARD_VARIANT=simple

# 利用可能バリアント（カンマ区切り）
VITE_AVAILABLE_DASHBOARD_VARIANTS=simple,full,safe,debug,emergency,minimal,fixed,with-debug

# === Feature Flags ===
VITE_ENABLE_AI_REPLY=true
VITE_ENABLE_BULK_MESSAGING=true
VITE_ENABLE_INSTAGRAM_INTEGRATION=true
VITE_ENABLE_ADVANCED_REPORTING=false
VITE_ENABLE_DEBUG_MODE=false

# === Security Settings ===
# セッション有効期限（秒）
VITE_SESSION_TIMEOUT=3600

# API レート制限（リクエスト/分）
VITE_API_RATE_LIMIT=60

# === Development Settings ===
VITE_ENABLE_MOCK_SERVICES=false
VITE_LOG_LEVEL=info